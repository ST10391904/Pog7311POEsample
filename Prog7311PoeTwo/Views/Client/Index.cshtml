@model IEnumerable<Prog7311PoeTwo.Models.ClientDetails>

@{
    ViewData["Title"] = "Clients";
}

<h2>Clients</h2>

<p class="text-end">
    <a asp-action="Create" class="btn btn-primary">+ Add New Client</a>
</p>

<div class="table-card">

<table class="table table-hover">

    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ClientName</td>
                <td>@item.ClientEmail</td>
                <td>@item.ClientPhoneNumber</td>
                <td class="text-center">
                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.ClientID">Edit</a>
                    <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.ClientID">Details</a>
                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.ClientID">Delete</a>
                </td>
            </tr>
        }
    </tbody>

</table>

</div>