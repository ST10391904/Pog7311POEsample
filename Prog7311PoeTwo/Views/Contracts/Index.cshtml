@model IEnumerable<Prog7311PoeTwo.Models.Contracts>

@{
    ViewData["Title"] = "Contracts";
}

<h2>Contracts</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Add New Contract</a>
</p>

<div class="table-card">

    <table class="table table-hover">

        <thead>
            <tr>
                <th>Name</th>
                <th>Client</th>
                <th>ZAR</th>
                <th>Amount</th>
                <th>Start</th>
                <th>End</th>
                <th>Status</th>
                <th>File</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(item.ContractName)</td>
                    <td>@(item.ClientDetails == default ? "N/A" : item.ClientDetails.ClientName)</td>
                    <td>@item.Amount.ToString("F2")</td>
                    <td>@item.AmountInZAR.ToString("F2")</td>
                    
                    <td>@(item.StartDate == default ? "N/A" : item.StartDate.ToString("yyyy-MM-dd"))</td>
                    <td>@(item.EndDate == default ? "N/A" : item.EndDate.ToString("yyyy-MM-dd"))</td>
                    
                    <td>@item.Status</td>

                    <td>
                        @if (!string.IsNullOrEmpty(item.FilePath))
                        {
                            <a href="@item.FilePath"
                               target="_blank"
                               class="btn btn-success btn-sm">
                                Download
                            </a>

                            <br />

                            <small class="text-muted">@item.FileName</small>
                        }
                        else
                        {
                            <span class="text-danger">No File</span>
                        }
                    </td>

                    <td class="text-center">
                        <a class="btn btn-danger btn-sm"
                           asp-action="Delete"
                           asp-route-id="@item.ContractID">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>

    </table>

</div>